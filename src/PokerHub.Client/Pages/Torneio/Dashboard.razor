    private void ShowInviteDialog() => _inviteDialogVisible = true;

    private string GetInviteUrl() =>
        _detail != null ? $"{Navigation.BaseUri}torneios/entrar/{_detail.InviteCode}" : "";

    private async Task CopyInviteLink()
    {
