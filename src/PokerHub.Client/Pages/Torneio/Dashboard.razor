    }

    private void ApplyPlayerUpdate(Guid playerId, Func<TournamentPlayerDto, TournamentPlayerDto> update)
    {
        if (_detail == null) return;
        var updated = _detail.Players.Select(p => p.PlayerId == playerId ? update(p) : p).ToList();
        _detail = _detail with { Players = updated };
        StateHasChanged();
    }

    private string GetPlayerName(Guid playerId) =>
        _detail?.Players.FirstOrDefault(p => p.PlayerId == playerId)?.PlayerName ?? "?";

    private bool IsPlayerPlaying(TournamentPlayerDto p) =>
        p.IsCheckedIn && !p.Position.HasValue && p.EliminatedAt == null;

    private bool IsPlayerEliminated(TournamentPlayerDto p) =>
        p.Position.HasValue || p.EliminatedAt != null;

    private int GetPlayersRemaining() =>
        _detail?.Players.Count(IsPlayerPlaying) ?? 0;

    private IEnumerable<TournamentPlayerDto> GetSortedPlayers()
    {
        if (_detail?.Players == null) return Enumerable.Empty<TournamentPlayerDto>();
        if (_detail.Status == TournamentStatus.Finished)
            return _detail.Players.OrderBy(p => p.Position ?? int.MaxValue).ThenBy(p => p.PlayerName);
        return _detail.Players.OrderBy(p => p.Position.HasValue ? 0 : 1).ThenBy(p => p.Position).ThenBy(p => p.PlayerName);
    }

    private TimerStateDto? BuildTimerState(TournamentDetailDto detail)
    {
        if (detail.Status is not (TournamentStatus.InProgress or TournamentStatus.Paused))
            return null;

        var current = detail.BlindLevels.FirstOrDefault(b => b.Order == detail.CurrentLevel);
        var next    = detail.BlindLevels.FirstOrDefault(b => b.Order == detail.CurrentLevel + 1);
        if (current == null) return null;

        var activePlayers = detail.Players.Count(p => p.IsCheckedIn && !p.EliminatedAt.HasValue);
        var totalPlayers  = detail.Players.Count(p => p.IsCheckedIn);

        return new TimerStateDto(
            TournamentId:         detail.Id,
            TournamentName:       detail.Name,
            Status:               detail.Status,
            CurrentLevel:         detail.CurrentLevel,
            TimeRemainingSeconds: detail.TimeRemainingSeconds ?? current.DurationMinutes * 60,
            CurrentBlindLevel:    current,
            NextBlindLevel:       next,
            PlayersRemaining:     activePlayers,
            TotalPlayers:         totalPlayers,
            PrizePool:            detail.PrizePool,
            TotalRebuys:          detail.Players.Sum(p => p.RebuyCount),
            TotalAddons:          detail.Players.Count(p => p.HasAddon)
        );
    }

    private string FormatTime(int secs)
    {
        if (secs < 0) secs = 0;
        return $"{secs / 60:D2}:{secs % 60:D2}";
    }

    private string FormatChips(decimal value)
    {
        if (value >= 1_000_000) return $"{value / 1_000_000:0.#}M";
        if (value >= 1_000)     return $"{value / 1_000:0.#}K";
        return value.ToString("0");
    }

    private string GetTimeColor()
    {
        if (_timerState == null) return "var(--mud-palette-text-primary)";
        if (_timerState.TimeRemainingSeconds <= 10) return "#ef4444";
        if (_timerState.TimeRemainingSeconds <= 60) return "#eab308";
        return "var(--mud-palette-text-primary)";
    }

    private Color GetStatusColor(TournamentStatus s) => s switch
    {
        TournamentStatus.Scheduled  => Color.Info,
        TournamentStatus.InProgress => Color.Success,
        TournamentStatus.Paused     => Color.Warning,
        TournamentStatus.Finished   => Color.Default,
        TournamentStatus.Cancelled  => Color.Error,
        _                           => Color.Default
    };

    private string GetStatusText(TournamentStatus s) => s switch
    {
        TournamentStatus.Scheduled  => "Agendado",
        TournamentStatus.InProgress => "EM ANDAMENTO",
        TournamentStatus.Paused     => "Pausado",
        TournamentStatus.Finished   => "Finalizado",
        TournamentStatus.Cancelled  => "Cancelado",
        _                           => s.ToString()
    };

    private Color GetPlayerStatusColor(TournamentPlayerDto p)
    {
        if (IsPlayerEliminated(p)) return Color.Error;
        if (p.IsCheckedIn)         return Color.Success;
        return Color.Default;
    }

    private string GetPlayerStatusText(TournamentPlayerDto p)
    {
        if (IsPlayerEliminated(p)) return $"{p.Position}º";
        if (p.IsCheckedIn)         return "Ativo";
        return "Aguardando";
    }

    private Color GetPositionColor(int pos) => pos switch
    {
        1 => Color.Warning,
        2 => Color.Secondary,
        3 => Color.Tertiary,
        _ => Color.Default
    };

