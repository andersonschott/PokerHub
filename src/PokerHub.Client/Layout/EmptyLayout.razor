@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" Theme="_theme" />

@Body

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#4CAF50",
            Secondary = "#FFD54F",
            Background = "#0d0d0d",
        }
    };
}
